{
  "title": "Public green spaces",
  "shortName": "public-green-spaces",
  "description": "A web component that displays a city’s public green asset inventory, including trees, parks, and other urban green infrastructure. It provides a clear, interactive view of public assets related to green space management",
  "descriptionAbstract": "An interactive web component for visualizing and exploring a city's public green asset inventory, supporting efficient management, monitoring, and planning of urban green infrastructure.",
  "license": "AGPL-3.0-or-later",
  "repositoryUrl": "https://github.com/noi-techpark/webcomp-public-green-spaces.git",
  "copyrightHolders": [
    {
      "name": "NOI",
      "email": "info@noi.bz.it",
      "organization": "NOI S.p.A",
      "organizationUrl": "https://noi.bz.it"
    }
  ],
  "authors": [
    {
      "name": "Samuel Yohanna",
      "email": "samuel.yohanna@r3gis.com",
      "organization": "R3Gis",
      "organizationUrl": "https://r3gis.com"
    },
    {
      "name": "Nicola Manica",
      "email": "nicola.manica@r3gis.com",
      "organization": "R3Gis",
      "organizationUrl": "https://r3gis.com"
    }
  ],
  "image": "wcs-logo.png",
  "searchTags": [],
  "dist": {
    "basePath": "dist",
    "files": [
      "webcomp-boilerplate.min.js",
      "maplibre-gl.js",
      "maplibre-gl.css",
      "maplibre-gl.js.LICENSE.txt"
    ],
    "scripts": [
      {
        "file": "maplibre-gl.js",
        "parameter": ""
      },
      {
        "file": "webcomp-boilerplate.min.js",
        "parameter": ""
      }
    ]
  },
  "configuration": {
    "tagName": "r3gis-urbangreen-v2",
    "options": [
      {
        "key": "zoom",
        "type": "text",
        "required": false,
        "label": "Initial zoom (e.g. 13 or 13.5)",
        "options": {
          "default": "13"
        }
      },
      {
        "key": "lat",
        "type": "text",
        "required": false,
        "label": "Initial latitude (e.g. 45.4064)",
        "options": {
          "default": ""
        }
      },
      {
        "key": "lng",
        "type": "text",
        "required": false,
        "label": "Initial longitude (e.g. 11.8768)",
        "options": {
          "default": ""
        }
      },
      {
        "key": "city",
        "type": "text",
        "required": false,
        "label": "City name (OpenStreetMap geocoding)",
        "options": {
          "default": ""
        }
      },
      {
        "key": "country",
        "type": "text",
        "required": false,
        "label": "Country / region (optional, for city disambiguation)",
        "options": {
          "default": ""
        }
      },
      {
        "key": "layers",
        "type": "multiselect",
        "required": false,
        "label": "Layers da mostrare",
        "options": {
          "values": [
            "1:all",
            "1:trees",
            "1:hedges",
            "1:lawns",
            "1:flowerbeds",
            "2:all",
            "2:street",
            "2:boundaries",
            "2:ground",
            "2:utilities",
            "2:structures",
            "3:all",
            "3:boundary",
            "3:playground",
            "3:temporary"
          ],
          "default": "1:all"
        }
      }

    ]
  }
}
