      "name": "Samuel Yohanna",
      "email": "samuel.yohanna@r3gis.com",
      "organization": "R3Gis",
      "organizationUrl": "https://r3gis.com"
    },
    {
      "name": "Nicola Manica",
      "email": "nicola.manica@r3gis.com",
      "organization": "R3Gis",
      "organizationUrl": "https://r3gis.com"
    }
  ],
  "image": "wcs-logo.png",
  "searchTags": [],
  "dist": {
    "basePath": "dist",
    "files": [
      "webcomp-boilerplate.min.js"
    ],
    "scripts": [
    ]
  },
  "configuration": {
    "tagName": "",
    "options": [
      {
        "key": "pmtiles-url",
        "type": "text",
        "label": "url of the pmtiles which contains objects",
        "required": false,
        "options": {
          "default": ""
        }
      },
      {
        "key": "zoom",
        "type": "number",
        "required": false,
        "label": "Initial zoom",
        "options": {
          "default": 13
        }
      },
      {
        "key": "lat",
        "type": "number",
        "required": false,
        "label": "Initial latitude",
        "options": {
          "default": 45.4064
        }
      },
      {
        "key": "lng",
        "type": "number",
        "required": false,
        "label": "Initial longitude",
        "options": {
          "default": 11.8768
        }
      },
      {
        "key": "city",
        "type": "text",
        "required": false,
        "label": "City name (OpenStreetMap geocoding)",
        "options": {
          "default": ""
        }
      },
      {
        "key": "country",
        "type": "text",
        "required": false,
        "label": "Country / region (optional, for city disambiguation)",
        "options": {
          "default": ""
        }
      },
      {
        "key": "layers",
        "type": "multiselect",
        "required": false,
        "label": "Layers da mostrare",
        "options": {
          "values": [
            "1:all",
            "1:trees",
            "1:hedges",
            "1:lawns",
            "1:flowerbeds",
            "2:all",
            "2:street",
            "2:boundaries",
            "2:ground",
            "2:utilities",
            "2:structures",
            "3:all",
            "3:boundary",
            "3:playground",
            "3:temporary"
          ],
          "default": [
            "1:all"
          ]
        }
      }

    ]
  }
}
